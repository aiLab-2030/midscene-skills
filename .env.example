# ============================================
# Midscene 环境变量配置
# ============================================
# 
# 请参考 Midscene 官方文档配置所需的环境变量：
# https://midscenejs.com/model-config.html
#
# 常见配置示例：
#
# 使用 OpenAI 兼容 API：
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=your-api-key
# MIDSCENE_MODEL_NAME=gpt-4-vision-preview
#
# 使用自定义模型服务：
# OPENAI_BASE_URL=your-api-endpoint
# OPENAI_API_KEY=your-api-key
# MIDSCENE_MODEL_NAME=your-model-name
# MIDSCENE_OPENAI_INIT_CONFIG_JSON={"key":"value"}
#
# ============================================

# 示例：OpenAI API 配置
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=your-openai-api-key
# MIDSCENE_MODEL_NAME=gpt-4-vision-preview

# ============================================
# 调试选项
# ============================================

# 开启调试模式
# DEBUG=1
