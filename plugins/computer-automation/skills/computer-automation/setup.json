{
  "setupComplete": false,
  "prerequisites": {
    "nodeJs": {
      "required": true,
      "installed": false,
      "description": "Node.js >= 18.19.0 (npx will auto-download @midscene/cli)",
      "setupGuide": {
        "verifyCommand": "node --version"
      }
    },
    "macosAccessibility": {
      "required": true,
      "installed": false,
      "description": "macOS Accessibility permission for the terminal app",
      "setupGuide": {
        "instruction": "Go to System Settings > Privacy & Security > Accessibility, and enable your terminal app (Terminal/iTerm2/etc.)"
      }
    },
    "xcodeCliTools": {
      "required": true,
      "installed": false,
      "description": "Xcode Command Line Tools (for screenshot capabilities)",
      "setupGuide": {
        "verifyCommand": "xcode-select -p",
        "installCommand": "xcode-select --install"
      }
    },
    "apiKey": {
      "required": true,
      "configured": false,
      "description": "AI Model API key via environment variable",
      "setupGuide": {
        "documentationUrl": "https://midscenejs.com/zh/model-common-config.html",
        "envVariables": {
          "required": ["MIDSCENE_MODEL_API_KEY"],
          "optional": ["MIDSCENE_MODEL_BASE_URL", "MIDSCENE_MODEL_NAME"]
        },
        "quickSetup": "export MIDSCENE_MODEL_API_KEY=your-api-key"
      }
    }
  }
}
