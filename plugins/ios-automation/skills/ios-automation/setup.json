{
  "setupComplete": false,
  "prerequisites": {
    "nodeJs": {
      "required": true,
      "installed": false,
      "description": "Node.js >= 18.19.0 (npx will auto-download @midscene/cli)",
      "setupGuide": {
        "verifyCommand": "node --version"
      }
    },
    "webDriverAgent": {
      "required": true,
      "installed": false,
      "description": "WebDriverAgent running on the iOS device/simulator",
      "setupGuide": {
        "documentationUrl": "https://midscenejs.com/zh/usage-ios.html",
        "instruction": "Install and run WebDriverAgent on your iOS device or simulator. See Midscene iOS documentation for setup guide."
      }
    },
    "xcode": {
      "required": true,
      "installed": false,
      "description": "Xcode installed (for iOS Simulator or device provisioning)",
      "setupGuide": {
        "verifyCommand": "xcodebuild -version",
        "instruction": "Install Xcode from the Mac App Store"
      }
    },
    "apiKey": {
      "required": true,
      "configured": false,
      "description": "AI Model API key via environment variable",
      "setupGuide": {
        "documentationUrl": "https://midscenejs.com/zh/model-common-config.html",
        "envVariables": {
          "required": ["MIDSCENE_MODEL_API_KEY"],
          "optional": ["MIDSCENE_MODEL_BASE_URL", "MIDSCENE_MODEL_NAME"]
        },
        "quickSetup": "export MIDSCENE_MODEL_API_KEY=your-api-key"
      }
    }
  }
}
