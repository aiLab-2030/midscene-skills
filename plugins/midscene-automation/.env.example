# Midscene AI Model Configuration
# Documentation: https://midscenejs.com/zh/model-common-config.html

# ========== Basic Configuration ==========
MIDSCENE_MODEL_API_KEY=your-api-key
MIDSCENE_MODEL_BASE_URL=https://api.openai.com/v1
MIDSCENE_MODEL_NAME=gpt-4o

# ========== Optional: Model Family ==========
# MIDSCENE_MODEL_FAMILY=openai

# ========== Advanced: Multi-Model Setup ==========
# MIDSCENE_PLANNING_MODEL_API_KEY=your-planning-api-key
# MIDSCENE_PLANNING_MODEL_BASE_URL=your-planning-base-url
# MIDSCENE_PLANNING_MODEL_NAME=your-planning-model
# MIDSCENE_INSIGHT_MODEL_API_KEY=your-insight-api-key
# MIDSCENE_INSIGHT_MODEL_BASE_URL=your-insight-base-url
# MIDSCENE_INSIGHT_MODEL_NAME=your-insight-model
