{
  "setupComplete": false,
  "prerequisites": {
    "nodeJs": {
      "required": true,
      "installed": false,
      "description": "Node.js >= 18.19.0 (npx will auto-download @midscene/cli)",
      "setupGuide": {
        "verifyCommand": "node --version"
      }
    },
    "chromeExtension": {
      "required": false,
      "installed": false,
      "description": "Midscene Chrome Extension (only needed for Bridge mode to connect to real browser with cookies/sessions)",
      "setupGuide": {
        "documentationUrl": "https://midscenejs.com/bridge-mode-by-chrome-extension.html"
      }
    },
    "apiKey": {
      "required": true,
      "configured": false,
      "description": "AI Model API key via environment variable",
      "setupGuide": {
        "documentationUrl": "https://midscenejs.com/zh/model-common-config.html",
        "envVariables": {
          "required": ["MIDSCENE_MODEL_API_KEY"],
          "optional": ["MIDSCENE_MODEL_BASE_URL", "MIDSCENE_MODEL_NAME"]
        },
        "quickSetup": "export MIDSCENE_MODEL_API_KEY=your-api-key"
      }
    }
  }
}
